# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=livingsexy
DB_USER=
DB_PASSWORD=
DB_CERT=  # Optional — leave empty for local/no-SSL connections

# S3-compatible object storage (DO Spaces, Hetzner Object Storage, MinIO, etc.)
SPACES_ENDPOINT=https://ams3.digitaloceanspaces.com
SPACES_KEY=
SPACES_SECRET=
SPACES_NAME=livingsexy
SPACES_REGION=ams3
STORAGE_PUBLIC_URL=  # Optional — override public URL (e.g. https://images.limitless8.com)

# Anthropic
ANTHROPIC_API_KEY=

# Typesense
TYPESENSE_HOST=
TYPESENSE_PORT=443
TYPESENSE_PROTOCOL=https
TYPESENSE_API_KEY=

# Redis (for BullMQ job queue)
REDIS_URL=redis://localhost:6379

# Server
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Scraper
PLAYWRIGHT_HEADLESS=true
MAX_CONCURRENT_SCRAPES=2
REQUEST_DELAY_MS=1500

# Admin API
ADMIN_API_KEY=
